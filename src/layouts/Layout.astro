---
interface Props {
	title?: string;
}

const { title = "Portal de Autogestión" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portal de Autogestión" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<!-- 🚀 ESTA LÍNEA MAPEA TAILWIND AL INSTANTE -->
		<script src="https://cdn.tailwindcss.com"></script>
	</head>
	<body class="bg-gray-50 m-0 p-0">
		<slot />
	</body>
</html>